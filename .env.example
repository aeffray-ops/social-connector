# Copie ce fichier en `.env` (optionnel). La connexion est MANUELLE (aucun
# identifiant ici). `.env` est gitignore.

# Provider par defaut si --provider n'est pas passe (facebook|whatsapp|linkedin)
PROVIDER=facebook

# Optionnel : chemin du fichier de session. Defaut = celui du provider
# (./fb-state.json, ./wa-state.json, ./li-state.json)
# STATE_PATH=./fb-state.json

# Optionnel : "1" = headless (AUCUNE fenetre), "0" = navigateur VISIBLE.
# Le login force toujours une fenetre visible.
HEADLESS=0
