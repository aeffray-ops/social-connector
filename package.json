{
  "name": "social-connector",
  "version": "0.2.0",
  "description": "Multi-provider TypeScript library (Facebook, WhatsApp, LinkedIn): manual login via automated browser (Playwright), reused session, posting/sending messages.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "social-connector": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "login": "tsx src/cli.ts login --provider",
    "post": "tsx src/cli.ts post --provider",
    "status": "tsx src/cli.ts status --provider",
    "login:fb": "tsx src/cli.ts login --provider facebook",
    "login:wa": "tsx src/cli.ts login --provider whatsapp",
    "login:li": "tsx src/cli.ts login --provider linkedin",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "app:install": "npm run build && cd app/server && npm install && cd ../web && npm install",
    "app:dev": "concurrently -n server,web \"cd app/server && npm run dev\" \"cd app/web && npm run dev\"",
    "app:build": "npm run build && cd app/server && npm run build && cd ../web && npm run build",
    "app:start": "cd app/server && npm start"
  },
  "keywords": [
    "facebook",
    "whatsapp",
    "linkedin",
    "playwright",
    "automation",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "openai": "^6.42.0",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
